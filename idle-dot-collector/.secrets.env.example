# .secrets.env.example — Template for secrets and variables.
#
# CONVENTIONS:
#   Keys prefixed with VAR_  → pushed as GitHub Variables  (visible in workflow logs)
#   All other keys           → pushed as GitHub Secrets    (masked in logs)
#   Keys suffixed with _B64  → value is a FILE PATH; the file is base64-encoded before pushing
#
# STRUCTURE:
#   .secrets.env              → shared secrets (Slack, Asana, etc.) used by all projects
#   <project_name>/.secrets.env  → project-specific secrets (keystore, certs, app IDs)
#                                  Project values override root values.
#
# USAGE:
#   # Push shared + project-specific secrets to a repo:
#   ./scripts/push-secrets.sh --project my-app WebAvenueIG/my-app-repo
#
#   # Push shared secrets only:
#   ./scripts/push-secrets.sh WebAvenueIG/some-repo
#
#   # DRY RUN (no changes):
#   DRY_RUN=1 ./scripts/push-secrets.sh --project my-app WebAvenueIG/my-app-repo


# ══════════════════════════════════════════════════════════════════════════════
# SHARED — goes in root .secrets.env
# Applies to all projects. Put these in .secrets.env at the repo root.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Notifications ───────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
ASANA_ACCESS_TOKEN=your_asana_personal_access_token


# ══════════════════════════════════════════════════════════════════════════════
# PROJECT-SPECIFIC — goes in <project_name>/.secrets.env
# Copy the section below into your project folder's .secrets.env file.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Android Signing ─────────────────────────────────────────────────────────
# Path to the .jks keystore file (relative to build-agent repo root or absolute)
ANDROID_KEYSTORE_B64=./path/to/android.jks

ANDROID_KEYSTORE_PASSWORD=your_keystore_password
ANDROID_KEYSTORE_ALIAS=your_key_alias
ANDROID_KEY_PASSWORD=your_key_password

# ─── Google Play ─────────────────────────────────────────────────────────────
# Path to the Google Play service account JSON key file
GOOGLE_PLAY_JSON_KEY_B64=./path/to/google-play-key.json

# ─── iOS Signing ─────────────────────────────────────────────────────────────
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_API_KEY_ID=XXXXXXXXXX
APPLE_API_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Path to the App Store Connect API key (.p8 file)
APPLE_API_KEY_B64=./path/to/AuthKey_XXXXXXXXXX.p8

# Path to the distribution certificate (.p12 file)
APPLE_DIST_CERT_B64=./path/to/distribution.p12
APPLE_DIST_CERT_PASSWORD=your_cert_password

# Path to the provisioning profile (.mobileprovision file)
IOS_PROVISIONING_PROFILE_B64=./path/to/YourApp_AppStore.mobileprovision

# ─── App Config (Variables — non-sensitive, visible in logs) ─────────────────
VAR_APP_NAME=Your App Name
VAR_ANDROID_PACKAGE_NAME=com.yourorg.appname
VAR_IOS_BUNDLE_ID=com.yourorg.appname
VAR_IOS_SCHEME=App
VAR_GOOGLE_PLAY_TRACK=internal
VAR_TESTFLIGHT_GROUPS=Internal Testers
VAR_ASANA_PROJECT_ID=1234567890123456
VAR_SLACK_CHANNEL_ID=C0XXXXXXXXX
