# Fastlane Fastfile — SHARED Capacitor lanes (Infinity Games Build Agent)
#
# This file is imported into caller-repo Fastfiles via `import_from_git`:
#
#   import_from_git(
#     url:    'https://github.com/webavenue/build-agent',
#     branch: 'main',                                   # or tag: 'v1.0.0'
#     path:   'fastlane/capacitor/Fastfile',
#   )
#
# Caller responsibilities (kept per-repo, not centralised):
#   • Gemfile / Gemfile.lock — pins fastlane gem version
#   • fastlane/Appfile        — project-specific app_identifier / package_name
#   • fastlane/Pluginfile     — any per-project plugins
#   • fastlane/Fastfile       — `require 'dotenv'` + `Dotenv.load('../.env')`
#                               + `default_platform(:ios)` + the import_from_git
#
# iOS signing model:
#   This file assumes the self-hosted Mac mini setup where the distribution
#   cert lives in the host login keychain and `sigh` (via App Store Connect
#   API key) fetches/refreshes the provisioning profile at build time. There
#   is NO manual-signing path here — `IOS_PROVISIONING_PROFILE_NAME` is not
#   consumed anywhere in this file. Caller workflows call `ship_auto`.

# ─────────────────────────────────────────────
# ANDROID LANES
# ─────────────────────────────────────────────
platform :android do

  desc "Inject VERSION_CODE and VERSION_NAME into android/app/build.gradle"
  private_lane :set_android_version do
    version_code = ENV["VERSION_CODE"]
    version_name = ENV["VERSION_NAME"]

    next unless version_code && version_name

    build_gradle_path = File.join(ENV["CAPACITOR_PROJECT_PATH"], "android/app/build.gradle")
    content = File.read(build_gradle_path)
    content = content.gsub(/versionCode\s+\d+/, "versionCode #{version_code}")
    content = content.gsub(/versionName\s+"[^"]*"/, "versionName \"#{version_name}\"")
    File.write(build_gradle_path, content)

    UI.success("Version set → #{version_name} (#{version_code})")
  end

  desc "Fetch max version code from Play internal track, +1, write to NEXT_VERSION_CODE_FILE (or next_version_code.txt)"
  lane :fetch_next_version_code do
    max_live = 0
    begin
      codes = google_play_track_version_codes(
        track:        "internal",
        json_key:     ENV["GOOGLE_PLAY_JSON_KEY_PATH"],
        package_name: ENV["ANDROID_PACKAGE_NAME"],
      )
      max_live = (codes || []).max || 0
      UI.message("Play internal track max version code: #{max_live}")
    rescue => e
      # Internal track empty/unconfigured, or app not yet on Play — start from 0
      UI.important("Could not read internal track (#{e.class}: #{e.message}). Falling back to max_live=0.")
    end

    next_code = max_live + 1
    UI.success("Next version code: #{next_code} (last on internal: #{max_live})")

    out_file = ENV["NEXT_VERSION_CODE_FILE"] || File.expand_path("next_version_code.txt")
    File.write(out_file, next_code.to_s)
    UI.message("Wrote #{next_code} to #{out_file}")
  end

  desc "Abort if VERSION_CODE in .env is not higher than what's already on Play Store"
  private_lane :validate_android_version do
    intended = ENV["VERSION_CODE"].to_i
    max_live = 0

    ["internal", "alpha", "beta", "production"].each do |track|
      begin
        codes = google_play_track_version_codes(
          track:        track,
          json_key:     ENV["GOOGLE_PLAY_JSON_KEY_PATH"],
          package_name: ENV["ANDROID_PACKAGE_NAME"],
        )
        max_live = [max_live, codes.max || 0].max
      rescue
        # Track is empty or doesn't exist yet — skip
      end
    end

    if max_live == 0
      UI.message("No existing builds found on Play Store — proceeding with version code #{intended}.")
    elsif intended <= max_live
      UI.user_error!(
        "VERSION_CODE #{intended} is not higher than the latest on Play Store (#{max_live}).\n" \
        "Update VERSION_CODE in credentials/<project>/.env to at least #{max_live + 1} and retry."
      )
    else
      UI.success("Version code check passed — Play Store: #{max_live}, building: #{intended} ✓")
    end
  end

  desc "Build a signed Android APK (release) — installable artifact for QA / build-only CI runs"
  lane :build_apk do
    set_android_version
    gradle(
      task: "assemble",
      build_type: "Release",
      project_dir: File.expand_path(File.join(ENV['CAPACITOR_PROJECT_PATH'], 'android')),
      properties: {
        "android.injected.signing.store.file"     => File.expand_path(ENV['ANDROID_KEYSTORE_PATH']),
        "android.injected.signing.store.password" => ENV["ANDROID_KEYSTORE_PASSWORD"],
        "android.injected.signing.key.alias"      => ENV["ANDROID_KEYSTORE_ALIAS"],
        "android.injected.signing.key.password"   => ENV["ANDROID_KEY_PASSWORD"],
      }
    )
  end

  desc "Build a signed Android AAB (release)"
  lane :build do
    set_android_version
    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: File.expand_path(File.join(ENV['CAPACITOR_PROJECT_PATH'], 'android')),
      properties: {
        "android.injected.signing.store.file"     => File.expand_path(ENV['ANDROID_KEYSTORE_PATH']),
        "android.injected.signing.store.password" => ENV["ANDROID_KEYSTORE_PASSWORD"],
        "android.injected.signing.key.alias"      => ENV["ANDROID_KEYSTORE_ALIAS"],
        "android.injected.signing.key.password"   => ENV["ANDROID_KEY_PASSWORD"],
      }
    )
  end

  desc "Upload latest AAB to Google Play (internal track by default)"
  lane :upload do
    supply(
      track: ENV["GOOGLE_PLAY_TRACK"] || "internal",
      aab: lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH],
      json_key: ENV["GOOGLE_PLAY_JSON_KEY_PATH"],
      package_name: ENV["ANDROID_PACKAGE_NAME"],
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: false,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  desc "Build + Upload to Google Play in one shot"
  lane :ship do
    build
    upload
    notify_success("Android")
  end

end

# ─────────────────────────────────────────────
# iOS LANES — automatic signing (self-hosted Mac runner)
#
# `ship_auto` is the entry point called by capacitor-selfhosted.yml. It builds
# with `sigh`-fetched provisioning profile (via App Store Connect API key) and
# the distribution cert from the host login keychain. No manual signing path.
# ─────────────────────────────────────────────
platform :ios do

  desc "Inject VERSION_NAME and VERSION_CODE into the Xcode project"
  private_lane :set_ios_version do
    version_name = ENV["VERSION_NAME"]
    version_code = ENV["VERSION_CODE"]

    next unless version_name && version_code

    xcodeproj = File.expand_path(File.join(ENV["CAPACITOR_PROJECT_PATH"], "ios/App/App.xcodeproj"))

    increment_version_number(
      version_number: version_name,
      xcodeproj:      xcodeproj,
    )
    increment_build_number(
      build_number: version_code,
      xcodeproj:    xcodeproj,
    )

    UI.success("Version set → #{version_name} (#{version_code})")
  end

  desc "Configure App Store Connect API auth"
  private_lane :setup_api_key do
    app_store_connect_api_key(
      key_id:        ENV["APPLE_API_KEY_ID"],
      issuer_id:     ENV["APPLE_API_ISSUER_ID"],
      key_filepath:  ENV["APPLE_API_KEY_PATH"],
      in_house:      false,
    )
  end

  desc "Fetch max TestFlight build number, +1, write to NEXT_BUILD_NUMBER_FILE (or next_build_number.txt)"
  lane :fetch_next_build_number do
    setup_api_key
    next_num = 1
    begin
      # No `version` arg → returns max build number across ALL versions on
      # TestFlight (not just the current version_name). This gives us a
      # monotonically increasing CFBundleVersion that Apple always accepts,
      # regardless of how the version_name moves.
      latest = latest_testflight_build_number(
        app_identifier:        ENV["IOS_BUNDLE_ID"],
        initial_build_number:  0,
      )
      next_num = latest.to_i + 1
      UI.success("Latest TestFlight build number: #{latest} → next: #{next_num}")
    rescue => e
      # App not yet on TestFlight, transient API error, etc. — start at 1.
      UI.important("Could not fetch latest TestFlight build (#{e.class}: #{e.message}). Falling back to 1.")
    end

    out_file = ENV["NEXT_BUILD_NUMBER_FILE"] || File.expand_path("next_build_number.txt")
    File.write(out_file, next_num.to_s)
    UI.message("Wrote #{next_num} to #{out_file}")
  end

  desc "Download AppLovin Quality Service (Ad Review) xcframework if missing"
  private_lane :ensure_applovin_quality_service do
    ios_dir = File.expand_path(File.join(ENV['CAPACITOR_PROJECT_PATH'], 'ios/App'))
    setup_script = File.join(ios_dir, 'AppLovinQualityServiceSetup-ios.rb')
    xcframework  = File.join(ios_dir, 'AppLovinQualityService', 'AppLovinQualityService.xcframework')

    # Self-detecting: skip silently if project doesn't use AppLovin Quality Service.
    next unless File.exist?(setup_script)
    next if Dir.exist?(xcframework)

    UI.message("AppLovinQualityService.xcframework not found — running setup script…")
    Dir.chdir(ios_dir) do
      sh("ruby", "AppLovinQualityServiceSetup-ios.rb")
    end
    UI.success("AppLovin Quality Service installed")
  end

  desc "Fetch/refresh Distribution profile via sigh, then patch App target to manual signing with it"
  private_lane :set_ios_signing_sigh do
    # sigh uses the API key (set up by setup_api_key above) to create or
    # refresh an App Store distribution provisioning profile. The profile
    # is downloaded and installed in ~/Library/MobileDevice/Provisioning Profiles.
    # No .mobileprovision secret needed — Apple manages the profile, sigh fetches it.
    get_provisioning_profile(
      app_identifier: ENV["IOS_BUNDLE_ID"],
      development:    false,    # We want a distribution profile, not development
      force:          false,    # Reuse existing if still valid (renews only when needed)
    )

    xcodeproj = File.expand_path(File.join(ENV["CAPACITOR_PROJECT_PATH"], "ios/App/App.xcodeproj"))
    update_code_signing_settings(
      use_automatic_signing: false,                                # Must be manual — automatic always picks dev profile for archive
      path:               xcodeproj,
      targets:            ["App"],                                 # ONLY the App target — leaves Pods/SPM untouched
      team_id:            ENV["APPLE_TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      profile_name:       lane_context[SharedValues::SIGH_NAME],   # Profile name returned by sigh above
      bundle_identifier:  ENV["IOS_BUNDLE_ID"],
    )
  end

  desc "Build a signed iOS IPA on the self-hosted Mac runner — profile fetched via sigh, cert from host keychain"
  private_lane :build_auto do
    set_ios_version
    setup_api_key                  # App Store Connect API key — needed by sigh below + gym/pilot later
    set_ios_signing_sigh           # Fetches Distribution profile, patches App target to manual signing
    ensure_applovin_quality_service
    workspace = File.expand_path(File.join(ENV['CAPACITOR_PROJECT_PATH'], 'ios/App/App.xcworkspace'))
    project   = File.expand_path(File.join(ENV['CAPACITOR_PROJECT_PATH'], 'ios/App/App.xcodeproj'))
    gym(
      scheme:           ENV["IOS_SCHEME"] || "App",
      workspace:        File.exist?(workspace) ? workspace : nil,
      project:          File.exist?(workspace) ? nil : project,
      configuration:    "Release",
      output_directory: "./build_output",
      clean:            true,
      export_options: {
        method:               "app-store",
        signingStyle:         "manual",
        signingCertificate:   "Apple Distribution",
        teamID:               ENV["APPLE_TEAM_ID"],
        provisioningProfiles: {
          ENV["IOS_BUNDLE_ID"] => lane_context[SharedValues::SIGH_NAME],
        },
      },
    )
  end

  desc "Upload IPA to TestFlight"
  lane :upload do
    setup_api_key
    pilot(
      ipa:              lane_context[SharedValues::IPA_OUTPUT_PATH],
      groups:           ENV["TESTFLIGHT_GROUPS"],
      skip_waiting_for_build_processing: true,
      # changelog omitted intentionally — supplying it forces fastlane to wait for
      # the build to appear in App Store Connect before it can attach the notes,
      # defeating skip_waiting_for_build_processing. Release notes are added
      # manually in TestFlight / App Store Connect after processing completes.
    )
  end

  desc "Build + Upload to TestFlight using automatic signing (sigh + host keychain cert)"
  lane :ship_auto do
    build_auto
    upload
    notify_success("iOS")
  end

end

# ─────────────────────────────────────────────
# HELPERS
# ─────────────────────────────────────────────
def notify_success(platform)
  puts ""
  puts "✅  #{platform} build shipped successfully!"
  puts "    App: #{ENV['APP_NAME']}"
  puts "    Time: #{Time.now}"
  puts ""
end
