#!/usr/bin/env bash
# App Store user ratings: all-time average per storefront (public iTunes lookup)
# + recent-review trend (App Store Connect API).
# Usage: ios_ratings <ios-bundle-id> [countries=us]
#   countries: comma-separated storefronts, e.g. "us,gb,de"
# CAVEAT: Apple ratings are CUMULATIVE for the app — there is no per-version
# rating. Build-vs-build on iOS = recent-trend (last ~50 reviews) vs all-time.
# Env (recent-trend part only): AGENT_ASC_KEY, AGENT_ASC_KEY_ID, AGENT_ASC_ISSUER_ID
set -euo pipefail
BUNDLE="${1:?usage: ios_ratings <ios-bundle-id> [countries]}"
COUNTRIES="${2:-us}"

echo "$BUNDLE — App Store ratings:"

# ── all-time average per storefront (public, no auth) ──────────────
BUNDLE="$BUNDLE" COUNTRIES="$COUNTRIES" python3 <<'PY'
import json, os, urllib.request
bundle = os.environ["BUNDLE"]
for c in os.environ["COUNTRIES"].split(","):
    c = c.strip().lower()
    try:
        with urllib.request.urlopen(
            f"https://itunes.apple.com/lookup?bundleId={bundle}&country={c}", timeout=15
        ) as r:
            d = json.load(r)
    except Exception as e:
        print(f"  {c.upper()}: lookup failed ({e})"); continue
    if not d.get("results"):
        print(f"  {c.upper()}: not listed"); continue
    a = d["results"][0]
    print(f"  {c.upper()}: all-time avg {a.get('averageUserRating', 0):.2f} stars "
          f"from {a.get('userRatingCount', 0)} ratings (store version {a.get('version')})")
PY

# ── recent-review trend (needs the ASC key; skip gracefully without) ──
P8="${AGENT_ASC_KEY:-$HOME/Documents/Sensitive/Apple_AuthKey_383Q6C4L74.p8}"
if [ ! -f "$P8" ]; then
  echo "  recent trend: unavailable in this run (no store credential)"
  exit 0
fi
export ASC_P8="$P8"
export ASC_KID="${AGENT_ASC_KEY_ID:-383Q6C4L74}"
export ASC_ISS="${AGENT_ASC_ISSUER_ID:-69a6de8a-0e5a-47e3-e053-5b8c7c11a4d1}"
export ASC_BUNDLE="$BUNDLE"

RUBY=/opt/homebrew/opt/ruby/bin/ruby
[ -x "$RUBY" ] || RUBY="$(command -v ruby)"

"$RUBY" <<'RB'
require 'jwt'; require 'net/http'; require 'uri'; require 'json'; require 'openssl'
pk  = OpenSSL::PKey::EC.new(File.read(ENV['ASC_P8']))
now = Time.now.to_i
tok = JWT.encode({iss: ENV['ASC_ISS'], iat: now, exp: now + 1200, aud: 'appstoreconnect-v1'},
                 pk, 'ES256', {kid: ENV['ASC_KID'], typ: 'JWT'})
def get(path, tok)
  u = URI("https://api.appstoreconnect.apple.com#{path}")
  r = Net::HTTP.start(u.host, 443, use_ssl: true) { |h| h.get(u.request_uri, {'Authorization' => "Bearer #{tok}"}) }
  abort "  recent trend: ASC HTTP #{r.code}" unless r.code == '200'
  JSON.parse(r.body)
end
app = get("/v1/apps?filter[bundleId]=#{ENV['ASC_BUNDLE']}", tok)['data'][0] or abort '  recent trend: app not found'
revs = get("/v1/apps/#{app['id']}/customerReviews?sort=-createdDate&limit=50&fields[customerReviews]=rating,createdDate", tok)['data'] || []
if revs.empty?
  puts '  recent trend: no reviews returned'
else
  ratings = revs.map { |r| r['attributes']['rating'] }
  span = "#{revs.last['attributes']['createdDate'][0,10]} to #{revs.first['attributes']['createdDate'][0,10]}"
  puts format('  recent trend: avg %.2f stars over the last %d reviews (%s)',
              ratings.sum.to_f / ratings.size, ratings.size, span)
end
RB
