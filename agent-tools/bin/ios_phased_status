#!/usr/bin/env bash
# Latest App Store versions + phased-release state for a bundle id (App Store Connect API).
# Usage: ios_phased_status <ios-bundle-id>
# Env: AGENT_ASC_KEY (p8 path), AGENT_ASC_KEY_ID, AGENT_ASC_ISSUER_ID
set -euo pipefail
BUNDLE="${1:?usage: ios_phased_status <ios-bundle-id>}"
export ASC_P8="${AGENT_ASC_KEY:-$HOME/Documents/Sensitive/Apple_AuthKey_383Q6C4L74.p8}"
export ASC_KID="${AGENT_ASC_KEY_ID:-383Q6C4L74}"
export ASC_ISS="${AGENT_ASC_ISSUER_ID:-69a6de8a-0e5a-47e3-e053-5b8c7c11a4d1}"
export ASC_BUNDLE="$BUNDLE"

# jwt gem lives under Homebrew ruby, which may not be the default ruby
RUBY=/opt/homebrew/opt/ruby/bin/ruby
[ -x "$RUBY" ] || RUBY="$(command -v ruby)"

exec "$RUBY" <<'RB'
require 'jwt'; require 'net/http'; require 'uri'; require 'json'; require 'openssl'

pk  = OpenSSL::PKey::EC.new(File.read(ENV['ASC_P8']))
now = Time.now.to_i
tok = JWT.encode({iss: ENV['ASC_ISS'], iat: now, exp: now + 1200, aud: 'appstoreconnect-v1'},
                 pk, 'ES256', {kid: ENV['ASC_KID'], typ: 'JWT'})

def get(path, tok)
  u = URI("https://api.appstoreconnect.apple.com#{path}")
  r = Net::HTTP.start(u.host, 443, use_ssl: true) { |h| h.get(u.request_uri, {'Authorization' => "Bearer #{tok}"}) }
  abort "ASC HTTP #{r.code}: #{r.body[0, 300]}" unless r.code == '200'
  JSON.parse(r.body)
end

bundle = ENV['ASC_BUNDLE']
app = get("/v1/apps?filter[bundleId]=#{bundle}", tok)['data'][0]
abort "no app found for bundle #{bundle}" unless app
puts "#{app['attributes']['name']}  (appId=#{app['id']}, bundle=#{bundle})"

vs = get("/v1/apps/#{app['id']}/appStoreVersions?limit=5&fields[appStoreVersions]=versionString,appStoreState,releaseType,createdDate", tok)['data'] || []
vs.each do |v|
  a = v['attributes']
  puts "  #{a['versionString'].ljust(9)} state=#{a['appStoreState'].ljust(24)} release=#{a['releaseType']} created=#{a['createdDate']&.slice(0, 10)}"
end

if (top = vs[0])
  pr = get("/v1/appStoreVersions/#{top['id']}/appStoreVersionPhasedRelease", tok)['data']
  if pr
    a = pr['attributes']
    puts "phased release (#{top['attributes']['versionString']}): state=#{a['phasedReleaseState']} day=#{a['currentDayNumber']} (id=#{pr['id']})"
  else
    puts "phased release (#{top['attributes']['versionString']}): none / not phased"
  end
end
RB
