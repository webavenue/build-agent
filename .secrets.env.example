# .secrets.env.example — Template for secrets and variables.
#
# CONVENTIONS:
#   [secrets] section          → keys pushed as GitHub Secrets    (masked in logs)
#   [variables] section        → keys pushed as GitHub Variables  (visible in logs)
#   Keys suffixed with _BASE64 or _B64 → value is a FILE PATH; base64-encoded before pushing
#
# STRUCTURE:
#   .secrets.env                     → shared secrets used by all projects
#   <project_name>/.secrets.env      → project-specific secrets (overrides root values)
#
# USAGE:
#   # Push shared + project-specific secrets to a repo:
#   ./scripts/push-secrets.sh --project my-app WebAvenueIG/my-app-repo
#
#   # Push shared secrets only:
#   ./scripts/push-secrets.sh WebAvenueIG/some-repo
#
#   # DRY RUN (no changes):
#   DRY_RUN=1 ./scripts/push-secrets.sh --project my-app WebAvenueIG/my-app-repo


# ══════════════════════════════════════════════════════════════════════════════
# SHARED — root .secrets.env
# ══════════════════════════════════════════════════════════════════════════════

[secrets]
APPLE_API_KEY_ID=XXXXXXXXXX
APPLE_API_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Paths to files — base64-encoded before pushing
APPLE_API_KEY_BASE64=./path/to/AuthKey_XXXXXXXXXX.p8
APPLE_DIST_CERT_BASE64=./path/to/distribution.p12
APPLE_DIST_CERT_PASSWORD=your_cert_password
APPLE_PROVISIONING_PROFILE_BASE64=./path/to/YourApp_AppStore.mobileprovision
GOOGLE_PLAY_JSON_KEY_BASE64=./path/to/google-play-key.json

SLACK_BOT_TOKEN=xoxb-...
ASANA_ACCESS_TOKEN=your_asana_personal_access_token

# Unity Pro licensing (used by unity.yml — ignore if you only build Capacitor apps)
UNITY_EMAIL=ci@yourorg.com
UNITY_PASSWORD=your_unity_password
UNITY_SERIAL=SC-XXXX-XXXX-XXXX-XXXX-XXXX

[variables]
APPLE_TEAM_ID=XXXXXXXXXX
ASANA_QA_PROJECT_ID=1234567890123456
ASANA_COLLABORATOR_IDS=1234567890123456,9876543210987654


# ══════════════════════════════════════════════════════════════════════════════
# PROJECT-SPECIFIC — <project_name>/.secrets.env
# ══════════════════════════════════════════════════════════════════════════════

[secrets]
ANDROID_KEYSTORE_BASE64=./project-name/android.jks
ANDROID_KEYSTORE_PASSWORD=your_keystore_password
ANDROID_KEYSTORE_ALIAS=your_key_alias
ANDROID_KEY_PASSWORD=your_key_password

[variables]
APP_NAME=Your App Name
ANDROID_PACKAGE_NAME=com.yourorg.appname
IOS_BUNDLE_ID=com.yourorg.appname
IOS_SCHEME=App
GOOGLE_PLAY_TRACK=internal
TESTFLIGHT_GROUPS=Internal Testers
SLACK_CHANNEL_ID=C0XXXXXXXXX
ASANA_PROJECT_ID=1234567890123456
ASANA_ASSIGNEE_ID=1234567890123456
